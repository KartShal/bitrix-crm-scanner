{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' *.bitrix24.kz *.bitrix24.ru *.bitrix24.com ukqss.bitrix24.kz;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/index.html", "destination": "/api/index" },
    { "source": "/install.html", "destination": "/api/install" },
    { "source": "/", "destination": "/api/index" }
  ]
}